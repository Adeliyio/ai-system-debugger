# Application
ASD_DEBUG=true
ASD_APP_NAME=AI System Debugger
ASD_APP_VERSION=0.1.0
ASD_API_HOST=0.0.0.0
ASD_API_PORT=8000
ASD_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Database
ASD_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_debugger
ASD_REDIS_URL=redis://localhost:6379/0

# OpenAI
ASD_OPENAI_API_KEY=your-api-key-here
ASD_OPENAI_MODEL=gpt-4o

# Local Model (Llama via Ollama)
ASD_LOCAL_MODEL_ENDPOINT=http://localhost:11434
ASD_LOCAL_MODEL_NAME=llama3.2

# Routing
ASD_COMPLEXITY_THRESHOLD=0.65

# Evaluation
ASD_SIMILARITY_THRESHOLD=0.65
ASD_ENSEMBLE_AGREEMENT_THRESHOLD=2

# Self-Healing
ASD_MAX_REPAIR_ATTEMPTS=2
ASD_REGRESSION_SUITE_SIZE=20
ASD_RELEVANCE_DEGRADATION_LIMIT=0.05

# A/B Testing
ASD_SHADOW_TRAFFIC_PERCENTAGE=0.10
ASD_SHADOW_TEST_DURATION_HOURS=24

# Drift Detection
ASD_DRIFT_WINDOW_DAYS=7
