# Application
ASD_DEBUG=false
ASD_API_HOST=0.0.0.0
ASD_API_PORT=8000

# Database
ASD_DATABASE_URL=postgresql+asyncpg://localhost:5432/ai_debugger
ASD_REDIS_URL=redis://localhost:6379/0

# OpenAI
ASD_OPENAI_API_KEY=your-api-key-here
ASD_OPENAI_MODEL=gpt-4o

# Local Model (Llama via Ollama)
ASD_LOCAL_MODEL_ENDPOINT=http://localhost:11434
ASD_LOCAL_MODEL_NAME=llama3.2

# Routing
ASD_COMPLEXITY_THRESHOLD=0.65

# Evaluation
ASD_SIMILARITY_THRESHOLD=0.65
